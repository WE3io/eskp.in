# Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenRouter (primary cloud provider for orchestration layer)
OPENROUTER_API_KEY=REPLACE_ME

# Claude Code Agent Teams (experimental)
CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Database
DATABASE_URL=postgresql://platform:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5432/platform

# Cloudflare
CLOUDFLARE_API_TOKEN=REPLACE_ME
CLOUDFLARE_ZONE_ID=REPLACE_ME
DOMAIN=yourdomain.com

# Email (Resend — resend.com)
EMAIL_API_KEY=REPLACE_ME
EMAIL_FROM_ADDRESS=hello@mail.yourdomain.com
EMAIL_REPLY_TO=panel@yourdomain.com
PANEL_EMAIL=panel@yourdomain.com

# Reply-to token secret — used to generate and verify HMAC-signed reply-to addresses
# (reply+{goalId}_{token}@mail.yourdomain.com) so user replies route to the right goal.
# Generate with: openssl rand -hex 32
# IMPORTANT: also add reply@mail.yourdomain.com as a Cloudflare Email Routing address
# pointing to the same worker as hello@mail.yourdomain.com (or use a catch-all rule).
REPLY_TOKEN_SECRET=REPLACE_ME

# Budget (in USD — the Claude instance uses this to self-regulate)
MONTHLY_TOKEN_BUDGET=30
# Infrastructure monthly cost in GBP (Hetzner server) — used for phase transition detection
INFRA_MONTHLY_GBP=4.00

# X (Twitter) — @awebot1529222
X_CONSUMER_KEY=REPLACE_ME
X_CONSUMER_SECRET=REPLACE_ME
X_BEARER_TOKEN=REPLACE_ME
X_ACCESS_TOKEN=REPLACE_ME
X_ACCESS_TOKEN_SECRET=REPLACE_ME
X_CLIENT_ID=REPLACE_ME
X_CLIENT_SECRET=REPLACE_ME

# Auto-session notifications
# Set to true to receive an email after every successful auto-session
NOTIFY_ON_SUCCESS=true

# Alert recipient for auto-session failures and monitoring alerts
# Defaults to the EMAIL_REPLY_TO address if not set
ALERT_EMAIL=admin@yourdomain.com

# Backblaze B2 — off-site backup
B2_KEY_ID=REPLACE_ME
B2_APP_KEY=REPLACE_ME
B2_BUCKET=eskp-backups
B2_BUCKET_ID=REPLACE_ME

# Application
NODE_ENV=production
PORT=3000
BASE_URL=https://yourdomain.com
